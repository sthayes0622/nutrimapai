{
  "name": "nutrimapai",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && node electron/copy-static.js && electron-builder build --mac --publish never",
    "electron:build:win": "npm run build && node electron/copy-static.js && electron-builder build --win --publish never"
  },
  "build": {
    "appId": "com.nutrimapai.app",
    "productName": "NutriMap AI",
    "files": [
      "electron/main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone/server.js",
        "to": "server/server.js"
      },
      {
        "from": ".next/standalone/package.json",
        "to": "server/package.json"
      },
      {
        "from": ".next/standalone/.next",
        "to": "server/.next"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": ".next/standalone/public",
        "to": "server/public"
      },
      {
        "from": ".env.local",
        "to": ".env.local"
      }
    ],
    "afterSign": "electron/notarize.js",
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "NutriMap AI",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@stripe/stripe-js": "^4.9.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "14.2.29",
    "next-auth": "^4.24.11",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
